#!/usr/bin/env bash
set -euo pipefail

if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 2) )); then
  printf 'lmline: bash 4.2 or newer is required; current version is %s\n' "$BASH_VERSION" >&2
  exit 2
fi

config_dir=${LMLINE_CONFIG_DIR:-$HOME/.config/lmline}
history_dir=${LMLINE_HISTORY_DIR:-$config_dir/history}
config_file=$config_dir/settings.bash
endpoints_file=$config_dir/endpoints.tsv
models_file=$config_dir/models.tsv
__lmline_tmp_paths=()
__lmline_cleanup() {
  ((${#__lmline_tmp_paths[@]} == 0)) || rm -rf "${__lmline_tmp_paths[@]}"
}
trap __lmline_cleanup EXIT

__lmline_mktemp() {
  local __var=$1 path
  path=$(mktemp "$2") || exit 1
  __lmline_tmp_paths+=("$path")
  printf -v "$__var" '%s' "$path"
}

__lmline_mktemp_dir() {
  local __var=$1 path
  path=$(mktemp -d "$2") || exit 1
  __lmline_tmp_paths+=("$path")
  printf -v "$__var" '%s' "$path"
}

script_path=${BASH_SOURCE[0]}
while [[ -L "$script_path" ]]; do
  script_dir=${script_path%/*}
  [[ "$script_dir" == "$script_path" ]] && script_dir=.
  link_target=$(readlink "$script_path")
  case "$link_target" in
    /*) script_path=$link_target ;;
    *) script_path=$script_dir/$link_target ;;
  esac
done
script_dir=${script_path%/*}
[[ $script_dir == "$script_path" ]] && script_dir=.
script_dir=$(cd -- "$script_dir" && pwd -P)

# shellcheck source=lmline/config.bash
source "$script_dir/config.bash"
__lmline_load_all_config
# shellcheck source=lmline/http.bash
source "$script_dir/http.bash"
# shellcheck source=lmline/profiles.bash
source "$script_dir/profiles.bash"
: "${LMLINE_CANDIDATE_COUNT:=3}"
__lmline_init_dirs "$script_dir"
: "${LMLINE_PS0:=🍋‍🟩 }"

usage() {
  cat <<'EOF'
usage: lmline <command> [args]

commands:
  doctor [--check-api]    check local configuration; optionally call ENDPOINT/models
  context [LINE...]       print shell context sent to the engine
  command-exists COMMAND... check whether named commands are available locally
  command-info COMMAND... print local command path, kind, version, and help snippets
  commands [QUERY]        print local commands matching QUERY
  payload [MODE] [LINE...] print the OpenAI-compatible JSON payload without sending it
  clip [QUESTION...]      ask the model about current clipboard text
  clip --status           show selected clipboard provider
  clip --providers        list configured clipboard providers
  clip --use PROVIDER     persist selected clipboard provider
  clip --provider PROVIDER [QUESTION...]
                          use a clipboard provider for one request
  config get              print config with secrets redacted
  config set KEY VALUE    persist a LMLINE_* setting
  config unset KEY        remove a persisted setting
  config project-get      print ./.lmline.bash with secrets redacted
  config project-set KEY VALUE
                          persist a project-local LMLINE_* setting
  config project-unset KEY
                          remove a project-local LMLINE_* setting
  endpoint add NAME BASE_URL [options]
                          register or update an LLM endpoint
  endpoint list           list registered endpoints
  endpoint set-secret NAME [VALUE]
                          store endpoint API key in a 0600 file
  endpoint remove NAME [--keep-secret]
                          remove an endpoint, its models, and its secret
  model add ENDPOINT MODEL [options]
                          register or update a model under an endpoint
  model list [ENDPOINT]   list registered models
  model refresh ENDPOINT  import models from ENDPOINT/models
  model remove ENDPOINT MODEL
                          remove a registered model
  use ENDPOINT [MODEL]    activate a registered endpoint/model; MODEL can be
                          omitted when exactly one model is registered
  current                 show active endpoint/model match
  complete endpoints|models [ENDPOINT]|clipboard-providers
                          print completion candidates
  history show            show lmline recorded suggestions
  history tendencies      summarize recorded suggestions by mode
  risk COMMAND...         show risk level and reason
  help COMMAND...         show command summaries
  debug bindings          show lmline Readline bindings
  debug on|off            toggle verbose lmline status logging
  debug trace on|off      save engine request/response trace files
  keys                    show lmline key binding config variables
  explain COMMAND...      explain a command through the engine
  enable                  print .bashrc snippet
  disable                 print removal guidance
EOF
}

quote_bash() {
  __lmline_quote_single "$1"
}

__lmline_config_file_op() {
  local op=$1 file=$2 key=$3 value=${4-} tmp
  [[ "$key" =~ ^LMLINE_[A-Z0-9_]+$ ]] || {
    printf 'lmline: invalid key: %s\n' "$key" >&2
    exit 2
  }
  case "$op" in
    set)
      mkdir -p "${file%/*}"
      touch "$file"
      __lmline_mktemp tmp "${TMPDIR:-/tmp}/lmline-cfg.XXXXXX"
      grep -v -E "^export ${key}=" "$file" >"$tmp" || true
      printf 'export %s=%s\n' "$key" "$(quote_bash "$value")" >>"$tmp"
      mv "$tmp" "$file"
      chmod 600 "$file" 2>/dev/null || true
      ;;
    unset)
      [[ -f "$file" ]] || return 0
      __lmline_mktemp tmp "${TMPDIR:-/tmp}/lmline-cfg.XXXXXX"
      grep -v -E "^export ${key}=" "$file" >"$tmp" || true
      mv "$tmp" "$file"
      chmod 600 "$file" 2>/dev/null || true
      ;;
    *) return 2 ;;
  esac
}

write_config_value() {
  __lmline_config_file_op set "$config_file" "$1" "$2"
}

unset_config_value() {
  __lmline_config_file_op unset "$config_file" "$1"
}

print_config_redacted() {
  local file=${1:-$config_file}
  [[ -f "$file" ]] || return 0
  sed -E \
    -e 's/^(export LMLINE_[A-Z0-9_]*(TOKEN|SECRET|PASSWORD|PASS|KEY)=).*/\1***REDACTED***/' \
    "$file"
}

source_support_files() {
  local file
  for file in policy.bash context.bash actions.bash; do
    [[ -r "$script_dir/$file" ]] || {
      printf 'lmline: required support file missing: %s\n' "$script_dir/$file" >&2
      exit 1
    }
  done
  # shellcheck source=lmline/policy.bash
  source "$script_dir/policy.bash"
  # shellcheck source=lmline/context.bash
  source "$script_dir/context.bash"
  # shellcheck source=lmline/actions.bash
  source "$script_dir/actions.bash"
}

engine_path() {
  if [[ -n "${LMLINE_ENGINE:-}" ]]; then
    printf '%s\n' "$LMLINE_ENGINE"
  else
    printf '%s\n' "$script_dir/engine"
  fi
}

print_explanation() {
  local line=$1
  source_support_files
  printf 'Explaining...\n' >&2
  __lmline_print_explanation "$(engine_path)" bash "$line" "${#line}" "$LMLINE_PS0"
}

print_clip() {
  local question=$1
  source_support_files
  __lmline_print_clip "$(engine_path)" bash "$question" "$LMLINE_PS0"
}

print_command_status() {
  local file=$1 c
  while IFS= read -r c; do
    if command -v "$c" >/dev/null 2>&1; then
      printf 'ok command=%s path=%s\n' "$c" "$(command -v "$c")"
    else
      printf 'missing command=%s\n' "$c"
      printf '  -> install %s or check PATH\n' "$c"
    fi
  done < <(__lmline_read_list_file "$file")
}

cmd=${1-}
case "$cmd" in
  doctor)
    shift || true
    source_support_files
    resolved_engine=$(engine_path)
    printf 'config_dir=%s\n' "$config_dir"
    if [[ -x "$resolved_engine" ]]; then
      printf 'engine=%s (ok)\n' "$resolved_engine"
    elif [[ -e "$resolved_engine" ]]; then
      printf 'engine=%s (not executable)\n' "$resolved_engine"
    else
      printf 'engine=NOT FOUND\n'
    fi
    printf 'base_url=%s\n' "${LMLINE_BASE_URL:-not-configured}"
    printf 'model=%s\n' "${LMLINE_MODEL:-auto-discover}"
    if [[ -n "${LMLINE_API_KEY_FILE:-}" ]]; then
      printf 'auth=configured\n'
    else
      printf 'auth=not-configured\n'
      printf '  -> lmline endpoint set-secret ENDPOINT\n'
    fi
    printf '\nrequired_commands\n'
    required_file=$(__lmline_resolve_data_file doctor_required_commands \
      "${LMLINE_DOCTOR_REQUIRED_COMMANDS_FILE:-}" \
      "$LMLINE_USER_RULES_DIR/doctor_required_commands.txt" \
      "$LMLINE_DEFAULTS_DIR/doctor_required_commands.txt") || exit 1
    print_command_status "$required_file"
    printf '\noptional_commands\n'
    optional_file=$(__lmline_resolve_data_file doctor_optional_commands \
      "${LMLINE_DOCTOR_OPTIONAL_COMMANDS_FILE:-}" \
      "$LMLINE_USER_RULES_DIR/doctor_optional_commands.txt" \
      "$LMLINE_DEFAULTS_DIR/doctor_optional_commands.txt") || exit 1
    print_command_status "$optional_file"
    printf '\nprofiles\n'
    endpoint_count=0
    model_count=0
    [[ -f "$endpoints_file" ]] && endpoint_count=$(awk -F '\t' 'NF && $1 !~ /^#/ { c++ } END { print c+0 }' "$endpoints_file")
    [[ -f "$models_file" ]] && model_count=$(awk -F '\t' 'NF && $1 !~ /^#/ { c++ } END { print c+0 }' "$models_file")
    printf 'endpoints=%s\nmodels=%s\n' "$endpoint_count" "$model_count"
    profile_current | sed 's/^/active_/'
    printf '\ndefaults\n'
    for f in \
      command_prefix_words.txt \
      clipboard_providers.tsv \
      doctor_optional_commands.txt \
      doctor_required_commands.txt \
      file_search_excludes.txt \
      project_markers.tsv \
      risk_patterns.tsv \
      shell_syntax_words.txt \
      suggested_commands.txt; do
      if [[ -r "$LMLINE_DEFAULTS_DIR/$f" ]]; then
        printf '  %s: ok\n' "$f"
      else
        printf '  %s: MISSING\n' "$f"
      fi
    done
    if [[ "${1-}" == "--check-api" ]]; then
      printf '\napi_check\n'
      api_base=${LMLINE_BASE_URL:-}
      __lmline_mktemp api_header_tmp "${TMPDIR:-/tmp}/lmline-hdr.XXXXXX"
      # ${VAR-default} (no colon): an explicitly empty scheme means raw key.
      __lmline_http_build_headers "${LMLINE_API_KEY_FILE:-}" \
        "${LMLINE_AUTH_HEADER:-Authorization}" "${LMLINE_AUTH_SCHEME-Bearer}" "$api_header_tmp"
      if [[ -n "$api_base" ]] && __lmline_http_get "${api_base%/}/models" 5 >/dev/null 2>&1; then
        printf '  connection=ok\n'
      else
        printf '  connection=failed\n'
        printf '  -> check LMLINE_BASE_URL or run: lmline use ENDPOINT MODEL\n'
      fi
    fi
    printf '\nclipboard\n'
    __lmline_clipboard_status
    ;;
  context)
    shift || true
    source_support_files
    __lmline_mktemp tmp "${TMPDIR:-/tmp}/lmline-ctx.XXXXXX"
    __lmline_context_file "$tmp" "$*"
    cat "$tmp"
    ;;
  commands)
    shift || true
    source_support_files
    __lmline_tool_commands "$*"
    ;;
  command-exists)
    shift || true
    source_support_files
    __lmline_tool_command_exists "$*"
    ;;
  command-info)
    shift || true
    source_support_files
    __lmline_tool_command_info "$*"
    ;;
  payload)
    shift || true
    mode=generate
    case "${1-}" in
      generate|continue|rewrite|explain|fix|clip)
        mode=$1
        shift
        ;;
    esac
    line=$*
    source_support_files
    __lmline_mktemp_dir tmp "${TMPDIR:-/tmp}/lmline-payload.XXXXXX"
    printf '%s' "$line" >"$tmp/line"
    __lmline_context_file "$tmp/context" "$line"
    "$(engine_path)" --dry-run-payload --mode "$mode" --shell bash --cwd "$PWD" --point "${#line}" --line-file "$tmp/line" --context-file "$tmp/context" --n "$LMLINE_CANDIDATE_COUNT"
    ;;
  clip)
    shift || true
    source_support_files
    case "${1-}" in
      --status)
        __lmline_clipboard_status
        ;;
      --providers)
        __lmline_clipboard_provider_list
        ;;
      --use)
        provider=${2-}
        [[ -n "$provider" ]] || { printf 'lmline: clip --use requires PROVIDER\n' >&2; exit 2; }
        if [[ "$provider" != auto ]]; then
          LMLINE_CLIPBOARD_PROVIDER=$provider __lmline_clipboard_provider_line >/dev/null || exit 1
        fi
        write_config_value LMLINE_CLIPBOARD_PROVIDER "$provider"
        LMLINE_CLIPBOARD_PROVIDER=$provider __lmline_clipboard_status
        ;;
      --provider)
        provider=${2-}
        [[ -n "$provider" ]] || { printf 'lmline: clip --provider requires PROVIDER\n' >&2; exit 2; }
        shift 2
        LMLINE_CLIPBOARD_PROVIDER=$provider print_clip "$*"
        ;;
      *)
        print_clip "$*"
        ;;
    esac
    ;;
  config)
    sub=${2-}; shift 2 || true
    case "$sub" in
      get) print_config_redacted ;;
      set)
        key=${1-}; value=${2-}
        # An explicitly empty VALUE is allowed (e.g. LMLINE_AUTH_SCHEME='' for
        # raw-header authentication); the argument must still be present.
        [[ "$key" =~ ^LMLINE_[A-Z0-9_]+$ && $# -ge 2 ]] || {
          printf 'lmline: config set requires KEY like LMLINE_MODEL and VALUE\n' >&2
          exit 2
        }
        write_config_value "$key" "$value"
        ;;
      unset)
        key=${1-}
        [[ -n "$key" ]] || { usage; exit 2; }
        unset_config_value "$key"
        ;;
      project-get)
        print_config_redacted "$PWD/.lmline.bash"
        ;;
      project-set)
        key=${1-}; value=${2-}
        [[ -n "$key" && -n "$value" ]] || { usage; exit 2; }
        __lmline_config_file_op set "$PWD/.lmline.bash" "$key" "$value"
        ;;
      project-unset)
        key=${1-}
        [[ -n "$key" ]] || { usage; exit 2; }
        __lmline_config_file_op unset "$PWD/.lmline.bash" "$key"
        ;;
      *) usage; exit 2 ;;
    esac
    ;;
  endpoint)
    sub=${2-}; shift 2 || true
    case "$sub" in
      add) profile_endpoint_add "$@" ;;
      list) profile_endpoint_list ;;
      set-secret) profile_endpoint_set_secret "${1-}" "${2-}" ;;
      remove) profile_endpoint_remove "$@" ;;
      *) usage; exit 2 ;;
    esac
    ;;
  model)
    sub=${2-}; shift 2 || true
    case "$sub" in
      add) profile_model_add "$@" ;;
      list) profile_model_list "${1-}" ;;
      refresh) profile_model_refresh "${1-}" ;;
      remove) profile_model_remove "${1-}" "${2-}" ;;
      *) usage; exit 2 ;;
    esac
    ;;
  use)
    shift || true
    profile_use "${1-}" "${2-}"
    ;;
  current)
    profile_current
    ;;
  complete)
    case "${2-}" in
      endpoints) [[ -f "$endpoints_file" ]] && awk -F '\t' 'NF && $1 !~ /^#/ { print $1 }' "$endpoints_file" ;;
      models) profile_model_list "${3-}" | awk -F '\t' '{ print $2 }' ;;
      clipboard-providers)
        source_support_files
        printf 'auto\n'
        __lmline_clipboard_provider_names
        ;;
      *) usage; exit 2 ;;
    esac
    ;;
  history)
    case "${2-}" in
      show)
        if [[ -d "$history_dir" ]]; then
          find "$history_dir" -maxdepth 1 -type f -print -exec tail -n 40 {} \;
        fi
        ;;
      tendencies)
        suggestions=$history_dir/suggestions.log
        if [[ -f "$suggestions" ]]; then
          awk '
            /^mode=/ { sub(/^mode=/, "", $0); counts[$0]++; total++ }
            END {
              printf "total=%d\n", total
              for (mode in counts) printf "%s=%d\n", mode, counts[mode]
            }
          ' "$suggestions"
        fi
        ;;
      *) usage; exit 2 ;;
    esac
    ;;
  risk)
    shift
    [[ $# -gt 0 ]] || { usage; exit 2; }
    source_support_files
    risk=$(__lmline_risk_level "$*") || exit 1
    reason=$(__lmline_risk_reason "$*") || exit 1
    printf 'risk=%s\nreason=%s\n' "$risk" "$reason"
    ;;
  help)
    shift
    [[ $# -gt 0 ]] || { usage; exit 2; }
    source_support_files
    __lmline_collect_command_summaries "$*"
    ;;
  debug)
    case "${2-}" in
      bindings)
        bind -X 2>/dev/null | grep -F __lmline_ || true
        ;;
      on)
        write_config_value LMLINE_DEBUG 1
        write_config_value LMLINE_STATUS_MODE log
        ;;
      off)
        write_config_value LMLINE_DEBUG 0
        write_config_value LMLINE_STATUS_MODE inline
        ;;
      trace)
        case "${3-}" in
          on)
            write_config_value LMLINE_TRACE_DIR "$config_dir/traces"
            ;;
          off)
            unset_config_value LMLINE_TRACE_DIR
            ;;
          *) usage; exit 2 ;;
        esac
        ;;
      *) usage; exit 2 ;;
    esac
    ;;
  keys)
    cat <<EOF
LMLINE_KEY_GENERATE=${LMLINE_KEY_GENERATE:-\\C-x\\C-g}
LMLINE_KEY_REWRITE=${LMLINE_KEY_REWRITE:-\\C-x\\C-r}
LMLINE_KEY_NEXT=${LMLINE_KEY_NEXT:-\\C-x\\C-n}
LMLINE_KEY_PREV=${LMLINE_KEY_PREV:-\\C-x\\C-p}
LMLINE_KEY_EXPLAIN=${LMLINE_KEY_EXPLAIN:-\\C-x\\C-e}
LMLINE_KEY_FIX=${LMLINE_KEY_FIX:-\\C-x\\C-f}
LMLINE_KEY_CLIP=${LMLINE_KEY_CLIP:-\\C-x\\C-v}

Example:
  lmline config set LMLINE_KEY_GENERATE '\\C-g'
  source ~/.config/lmline/init.bash
EOF
    ;;
  explain)
    shift
    [[ $# -gt 0 ]] || { usage; exit 2; }
    print_explanation "$*"
    ;;
  enable)
    cat <<EOF
Add this to ~/.bashrc:

if [[ \$- == *i* ]]; then
  source "$config_dir/init.bash"
fi
EOF
    ;;
  disable)
    printf 'Remove or comment out the lmline source block from ~/.bashrc.\n'
    ;;
  -h|--help|'')
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
